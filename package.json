{
  "name": "multiline-string-editor",
  "version": "0.0.4",
  "author": "jensenturner",
  "repository": {
    "type": "git",
    "url": "https://github.com/jensenturner/vscode-multiline-string-editor"
  },
  "main": "./out/extension.js",
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.8.3"
  },
  "categories": [
    "Other"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jensenturner.multiline-string-editor.editMultiline",
        "title": "Edit as multiline string"
      }
    ]
  },
  "description": "Visual Studio Code extension for editing multiline strings (e.g., in JSON). Based on the Multiline String Editor extension by The Children's Hospital of Philadelphia at https://github.com/chop-dbhi/vscode-multiline-string-editor.",
  "displayName": "Multiline String Editor",
  "engines": {
    "vscode": "^1.100.0"
  },
  "homepage": "https://github.com/jensenturner/vscode-multiline-string-editor/blob/master/README.md",
  "keywords": [
    "JSON",
    "multiline",
    "multi-line",
    "string"
  ],
  "license": "MIT",
  "markdown": "github",
  "publisher": "jensenturner",
  "scripts": {
    "compile": "tsc",
    "watch": "tsc -watch",
    "package": "tsc && npx vsce package"
  }
}
